# Obsidian vault root (read-only input). Path has spaces — keep the quotes.
# Symlink target: /mnt/c/Users/Catalin Teodorescu/OneDrive/Documents/Obsidian Vault
VAULT_PATH="$HOME/obsidian.md"

# Claude Code session logs root.
CLAUDE_PROJECTS="$HOME/.claude/projects"

# claude.ai web conversations. Cloudflare Turnstile blocks any automated
# browser, so the collector instead ATTACHES over CDP to a real Chrome you run
# and have logged into claude.ai. Start it once:
#   chromium --remote-debugging-port=9222 \
#     --user-data-dir="$HOME/.cache/social-update/chrome-profile"
# then log into claude.ai in that window and leave it running. Unset = web
# conversations are not collected (local Claude Code sessions still are).
CLAUDE_CDP_URL="http://localhost:9222"
# claude.ai API base — only change if proxying. Default: https://claude.ai
CLAUDE_WEB_BASE="https://claude.ai"

# GitHub username whose public+private events the collector reads (via authed gh CLI).
GITHUB_USER="dustfeather"

# Repos to exclude from collection. Comma-separated "owner/repo".
# A trailing "/*" excludes a whole owner. Case-insensitive. Empty = no exclusions.
# Example: GITHUB_EXCLUDE_REPOS="dustfeather/scratch,acme-corp/*"
# NOTE: only used in pure-local mode. With INGEST_URL set, the exclude list comes
# from the server DB (set it in the UI's "GitHub repo filter" panel).
GITHUB_EXCLUDE_REPOS=""

# Local web server port.
PORT=4000

# SQLite database file (server / pure-local mode). In k3s this is a PVC path.
DB_PATH="$HOME/projects/social-update/social.sqlite"

# Remote ingest target for collectors. SET THIS on the collector machine to push
# items to the k3s deployment instead of a local DB. Unset = pure-local (writes DB_PATH).
# Example: INGEST_URL="https://social.itguys.ro"
INGEST_URL=""
